# =============================================================================
# Python / 构建 / IDE（标准忽略）
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.venv/
venv/
.mypy_cache/
.pytest_cache/
.hypothesis/
.vscode/
.idea/
*.swp
*.swo
*~
*.DS_Store

# =============================================================================
# 运行中间产物（不上传）
# =============================================================================
# smoke / 临时实验目录
tmp/
comparison_results/
image/

# 训练与评估过程日志
*.log
*.out
*.err

# 可视化中间帧、轨迹图（--print_images / dump 输出）
**/dump/**/images/
**/dump/**/episodes/
**/dump/**/tensorboard/

# episode 内周期 checkpoint、评估曲线（非最终 model_best）
**/dump/**/periodic_*
**/dump/**/explored_area.txt
**/dump/**/explored_ratio.txt

# 默认云盘训练输出目录（若在项目内克隆了一份）
nso_runs/

# 未归档的 torch 权重碎片（显式保留 yolov8n.pt，见下方 ! 规则）
*.pt
!yolov8n.pt

# =============================================================================
# 需要纳入版本库（请勿忽略）
# -----------------------------------------------------------------------------
# pretrained_models/     官方预训练 model_best.{slam,local,global}
# trained_models/        自训练各阶段最终 model_best.*
# data/                  数据集配置、场景元数据、pointnav json
# noise_models/          动作/传感器噪声 pkl
# *.pdf                  论文与数据协议文档
# yolov8n.pt             语义检测权重
# pointnav_*.zip         数据集压缩包（可选，与 data/ 二选一或并存）
# =============================================================================
